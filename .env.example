# BMDW Estimator — environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ──────────────────────────────────────────────────────────────
# REQUIRED — app is non-functional without these
# ──────────────────────────────────────────────────────────────

# Anthropic API key — powers the AI quick-notes parser and contract narrator.
# Get one at https://console.anthropic.com → Settings → API Keys.
ANTHROPIC_API_KEY=

# Password gate for the app. Anyone with the URL must enter this to use it.
# Set to a long random string. Leave blank to DISABLE the gate (NOT recommended in prod).
BMDW_APP_PASSWORD=


# ──────────────────────────────────────────────────────────────
# OPTIONAL — features degrade gracefully if missing
# ──────────────────────────────────────────────────────────────

# Anthropic model override. Default: claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Gmail OAuth — to actually send quote / contract emails.
# 1) Enable Gmail API in Google Cloud → 2) create Desktop OAuth client →
# 3) download client_secret.json → save as config/gmail_client_secret.json.
# No env var needed; the file's presence is what enables the feature.

# Google Sheets sync — service account JSON for accountant/CRA mirror.
# Save the service-account JSON as config/google_service_account.json,
# then set google_sheet_id in config/company.json.
